<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.steeringhub.repository.postgres.mapper.SysUserPOMapper">

    <select id="findByUsername" resultType="com.steeringhub.repository.postgres.po.SysUserPO">
        SELECT id, username, password, nickname, role, enabled, created_at, updated_at
        FROM sys_user
        WHERE username = #{username}
        LIMIT 1
    </select>

</mapper>
