<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.steeringhub.repository.postgres.mapper.ComplianceReportPOMapper">

    <select id="findByRepoId" resultType="com.steeringhub.repository.postgres.po.ComplianceReportPO">
        SELECT * FROM compliance_report
        WHERE repo_id = #{repoId}
        ORDER BY created_at DESC
        LIMIT #{limit}
    </select>

</mapper>
